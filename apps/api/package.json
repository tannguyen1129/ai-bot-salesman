{
  "name": "@vnetwork/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run migrate --workspace=@vnetwork/database",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "preworker": "npm run migrate --workspace=@vnetwork/database",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "lint": "echo 'lint not configured yet'"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@types/mailparser": "^3.4.6",
    "axios": "^1.9.0",
    "bullmq": "^5.52.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "imapflow": "^1.3.3",
    "ioredis": "^5.8.1",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
